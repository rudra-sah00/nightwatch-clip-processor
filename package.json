{
  "name": "nightwatch-clip-processor",
  "version": "1.0.0",
  "type": "module",
  "description": "Standalone clip processing worker for Nightwatch \u2014 FFmpeg pipeline, MinIO storage, BullMQ queue",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.34.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}